# Example GitHub Action: Auto-sync Figma Design System
# 
# This workflow would run automatically when Figma publishes changes
# triggering an MCP server to regenerate tokens.ts and contracts.ts
#
# To use:
# 1. Rename to .yml (remove .example)
# 2. Set up Figma webhook to trigger this workflow
# 3. Configure FIGMA_ACCESS_TOKEN in repository secrets

name: Sync Figma Design System

# Trigger options:
on:
  # Option 1: Figma webhook (recommended)
  repository_dispatch:
    types: [figma-publish]
  
  # Option 2: Manual trigger
  workflow_dispatch:
  
  # Option 3: Scheduled sync (every 6 hours)
  schedule:
    - cron: '0 */6 * * *'
  
  # Option 4: On push to main (for testing)
  # push:
  #   branches: [main]

jobs:
  sync-design-system:
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
      
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'
      
      - name: Install dependencies
        run: npm ci
      
      - name: Sync from Figma via MCP
        env:
          FIGMA_ACCESS_TOKEN: ${{ secrets.FIGMA_ACCESS_TOKEN }}
          FIGMA_FILE_ID: ${{ secrets.FIGMA_FILE_ID }}
        run: |
          # Run the MCP sync script
          npx tsx src/ai/mcp-sync.ts
          
          # Check if files changed
          if git diff --quiet src/design-system/tokens.ts src/design-system/contracts.ts; then
            echo "No changes detected - design system is up to date"
            exit 0
          fi
      
      - name: Run validation tests
        run: |
          # Ensure generated files are valid TypeScript
          npx tsc --noEmit
          
          # Run any design system validation tests
          npm run test -- src/design-system
      
      - name: Commit and push changes
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          
          git add src/design-system/tokens.ts src/design-system/contracts.ts
          git commit -m "chore(design-system): sync from Figma [skip ci]
          
          Auto-generated by MCP sync from Figma design system.
          Updated tokens and contracts to reflect latest design changes."
          
          git push
      
      - name: Create PR if changes are significant
        if: github.event_name == 'repository_dispatch'
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          # For major changes, create PR instead of direct push
          git checkout -b figma-sync-$(date +%s)
          git add src/design-system/tokens.ts src/design-system/contracts.ts
          git commit -m "chore(design-system): sync from Figma"
          git push origin HEAD
          
          gh pr create \
            --title "🎨 Design System Sync from Figma" \
            --body "Auto-generated changes from Figma design system.
            
            **Changes:**
            - Updated design tokens
            - Updated component contracts
            
            **Review:**
            - Verify all components still build
            - Check if validation logic needs updates
            - Test AI prompts with new contract
            " \
            --label "design-system,automated"
      
      - name: Notify on failure
        if: failure()
        run: |
          # Send notification (Slack, Discord, email, etc.)
          echo "❌ Figma sync failed - manual intervention required"

